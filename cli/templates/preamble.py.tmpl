# --- helpers ----------------------------------------------------------------
_AMU_KG = 1.66053906660e-27      # amu -> kg
_A3_M3 = 1.0e-30                 # Angstrom^3 -> m^3


def density_kg_m3(atoms):
    """Mass density of the (periodic) cell in kg/m^3 (NaN when it has no volume)."""
    volume = atoms.get_volume()
    if volume <= 0.0:
        return float("nan")
    return (atoms.get_masses().sum() * _AMU_KG) / (volume * _A3_M3)


def format_hms(seconds):
    """Seconds -> 'HH:MM:SS' (or '--:--:--' when unknown)."""
    if seconds is None or not np.isfinite(seconds):
        return "--:--:--"
    seconds = int(round(seconds))
    h, rem = divmod(seconds, 3600)
    m, s = divmod(rem, 60)
    return f"{h:02d}:{m:02d}:{s:02d}"


def backup_if_exists(path):
    """Rename an existing file to '<name>_backupN<ext>' so it is never clobbered."""
    if not path or not os.path.exists(path):
        return None
    root, ext = os.path.splitext(path)
    i = 1
    while os.path.exists(f"{root}_backup{i}{ext}"):
        i += 1
    backup = f"{root}_backup{i}{ext}"
    os.rename(path, backup)
    print(f"Existing '{path}' found -> renamed to '{backup}'", flush=True)
    return backup


